import os
import time
from datetime import datetime
from pathlib import Path

from dotenv import load_dotenv
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys

from src.utils.navegador import iniciar_navegador


BASE_DIR = Path(__file__).resolve().parents[2]

OUTPUTS_DIR = BASE_DIR / "outputs"
OUTPUTS_DIR.mkdir(exist_ok=True)

load_dotenv(BASE_DIR / ".env")


def executar_robo_moodle(periodo: str = "5º e 6º períodos"):
    """
    Fase 1 do AVA Intelligence:
    - abre o navegador headless;
    - acessa o Moodle;
    - realiza login automático;
    - salva screenshot;
    - gera log da execução.
    """

    moodle_url = os.getenv("MOODLE_URL")
    moodle_user = os.getenv("MOODLE_USER")
    moodle_password = os.getenv("MOODLE_PASSWORD")

    log = []
    inicio = datetime.now()

    log.append("ATHENA SCIENTIFIC | AVA INTELLIGENCE")
    log.append("=" * 60)
    log.append(f"Início: {inicio.strftime('%Y-%m-%d %H:%M:%S')}")
    log.append(f"Período selecionado: {periodo}")

    if not moodle_url or not moodle_user or not moodle_password:
        log.append("\n[ERRO]")
        log.append("As variáveis MOODLE_URL, MOODLE_USER ou MOODLE_PASSWORD não foram encontradas no .env.")

        log_path = OUTPUTS_DIR / "fase1_robo_moodle_log.txt"
        log_path.write_text("\n".join(log), encoding="utf-8")

        return {
            "sucesso": False,
            "log": "\n".join(log),
            "log_path": str(log_path),
            "screenshot": None
        }

    driver = None
    sucesso = False
    screenshot_path = None

    try:
        log.append("\n[1] Abrindo navegador headless...")
        driver = iniciar_navegador()
        log.append("Navegador iniciado com sucesso.")

        log.append(f"\n[2] Acessando Moodle: {moodle_url}")
        driver.get(moodle_url)
        time.sleep(4)

        log.append("\n[3] Localizando campos de login...")

        username_input = driver.find_element(By.ID, "username")
        password_input = driver.find_element(By.ID, "password")

        log.append("Campos de login encontrados.")

        log.append("\n[4] Preenchendo credenciais...")

        username_input.clear()
        username_input.send_keys(moodle_user)

        password_input.clear()
        password_input.send_keys(moodle_password)

        time.sleep(1)

        log.append("[5] Enviando login com ENTER...")
        password_input.send_keys(Keys.ENTER)

        time.sleep(8)

        titulo = driver.title
        url_atual = driver.current_url

        log.append("\n[6] Verificação pós-login")
        log.append(f"Título da página: {titulo}")
        log.append(f"URL atual: {url_atual}")

        screenshot_path = OUTPUTS_DIR / "moodle_login_teste.png"
        driver.save_screenshot(str(screenshot_path))

        log.append(f"Screenshot salvo em: {screenshot_path}")

        if "login" in url_atual.lower():
            log.append("\nATENÇÃO: O Moodle ainda está na tela de login.")
            log.append("Possíveis causas: senha incorreta, bloqueio headless, captcha, sessão expirada ou botão/token especial.")
            sucesso = False
        else:
            log.append("\nLogin aparentemente realizado com sucesso.")
            sucesso = True

    except Exception as erro:
        log.append("\n[ERRO DURANTE EXECUÇÃO]")
        log.append(str(erro))
        sucesso = False

    finally:
        if driver:
            driver.quit()
            log.append("\nNavegador fechado.")

    fim = datetime.now()

    log.append(f"\nFim: {fim.strftime('%Y-%m-%d %H:%M:%S')}")
    log.append(f"Duração: {fim - inicio}")
    log.append("=" * 60)

    log_path = OUTPUTS_DIR / "fase1_robo_moodle_log.txt"
    log_path.write_text("\n".join(log), encoding="utf-8")

    return {
        "sucesso": sucesso,
        "log": "\n".join(log),
        "log_path": str(log_path),
        "screenshot": str(screenshot_path) if screenshot_path else None
    }
login_button = driver.find_element(By.ID, "loginbtn")

driver.execute_script(
    "arguments[0].click();",
    login_button
)

time.sleep(10)login_button = driver.find_element(By.ID, "loginbtn")

driver.execute_script(
    "arguments[0].click();",
    login_button
)

time.sleep(10)
